[Interface]
PrivateKey = {{ .PrivateKey }}
ListenPort = {{ .ListenPort }}
Address = {{ .Address }}
{{- if .Address6 }}
Address = {{ .Address6 }}
{{- end }}
{{- if .MTU }}
MTU = {{ .MTU }}
{{- end }}
{{- if .PostUp }}
PostUp = {{ .PostUp }}
{{- end }}
{{- if .PostDown }}
PostDown = {{ .PostDown }}
{{- end }}

{{ range .Peers }}
{{- /* Skip pending S2S peers: their PublicKey is empty until the
       remote side returns its ack token, and wg-quick refuses to
       parse a [Peer] block with no PublicKey. */ -}}
{{- if and (not .Pending) .PublicKey }}
[Peer]
# {{ .Name }}
PublicKey = {{ .PublicKey }}
{{- if .PresharedKey }}
PresharedKey = {{ .PresharedKey }}
{{- end }}
AllowedIPs = {{ .AllowedIPs }}
{{- if .Endpoint }}
Endpoint = {{ .Endpoint }}
{{- end }}
{{- if .Keepalive }}
PersistentKeepalive = {{ .Keepalive }}
{{- end }}
{{ end }}
{{- end }}
